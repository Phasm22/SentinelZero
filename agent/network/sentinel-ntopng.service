[Unit]
Description=SentinelZero ntopng Network Sensor
After=network-online.target sentinelzero.service
Wants=network-online.target
StartLimitIntervalSec=300
StartLimitBurst=5

[Service]
Type=simple
User=sentinel
Group=sentinel
WorkingDirectory=/home/sentinel/SentinelZero/agent/network
EnvironmentFile=-/etc/sentinel-ntopng/sensor.env
Environment=PYTHONDONTWRITEBYTECODE=1
ExecStartPre=/home/sentinel/SentinelZero/agent/network/wait-for-backend.sh
ExecStart=/home/sentinel/SentinelZero/agent/network/.venv/bin/python \
    /home/sentinel/SentinelZero/agent/network/ntopng_sensor.py \
    --config /etc/sentinel-ntopng/config.yaml
Restart=on-failure
RestartSec=15
TimeoutStopSec=15
KillMode=mixed
StandardOutput=journal
StandardError=journal
SyslogIdentifier=sentinel-ntopng

# ── Hardening ──────────────────────────────────────────────────────────────
NoNewPrivileges=true

# Filesystem isolation
# strict makes /usr /boot /etc read-only; sensor only reads its config from /etc
ProtectSystem=strict
ProtectHome=read-only
PrivateTmp=true
PrivateDevices=true

# Kernel protections
ProtectHostname=true
ProtectClock=true
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectKernelLogs=true
ProtectControlGroups=true

# Privilege restrictions — sensor needs no capabilities
CapabilityBoundingSet=
AmbientCapabilities=
RestrictSUIDSGID=true
LockPersonality=true

# Syscall and namespace filtering
RestrictNamespaces=true
RestrictAddressFamilies=AF_INET AF_INET6 AF_UNIX
SystemCallFilter=@system-service
SystemCallArchitectures=native

UMask=0077

[Install]
WantedBy=multi-user.target
